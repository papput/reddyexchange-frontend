# Copy to `.env` for local dev. Dev server runs on port 5015; Vite proxies `/api` → backend (see `vite.config.ts`, default backend PORT=5010).
VITE_API_BASE_URL=/api

# Production: set to your deployed API origin, e.g.:
# VITE_API_BASE_URL=https://your-api.example.com/api
# Ensure the backend `cors` `allowed` list in `backend/src/app.js` includes your frontend origin.
